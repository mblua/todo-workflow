#!/usr/bin/env bash
# todo-workflow pre-commit hook
# Enforces that Step 5 (Verified) is completed in the
# _issues/<repo>-<num>.md checklist before allowing commits on todo/* branches.

set -euo pipefail

# 1. Get current branch name
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || true)

# 2. Only enforce on todo/<num>-* branches
if [[ ! "$BRANCH" =~ ^todo/([0-9]+)- ]]; then
    exit 0
fi

ISSUE_NUM="${BASH_REMATCH[1]}"

# 3. Read .todo-workflow to find hub repo name
REPO_ROOT=$(git rev-parse --show-toplevel)
CONFIG_FILE="$REPO_ROOT/.todo-workflow"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "ERROR: .todo-workflow not found in repo root."
    echo "This file is required for pre-commit enforcement."
    echo "Create it with: hub=<hub-repo-name>"
    exit 1
fi

HUB_REPO=$(grep '^hub=' "$CONFIG_FILE" | cut -d= -f2 | tr -d '[:space:]')

if [[ -z "$HUB_REPO" ]]; then
    echo "ERROR: hub= not set in .todo-workflow"
    exit 1
fi

# 4. Locate the checklist file in the hub repo
# Hub repo is a sibling directory (same parent as this repo)
PARENT_DIR=$(dirname "$REPO_ROOT")

# Derive repo name from directory (strip trailing digits for workgroups: my-frontend3 -> my-frontend)
REPO_DIR_NAME=$(basename "$REPO_ROOT")
REPO_NAME=$(echo "$REPO_DIR_NAME" | sed 's/[0-9]*$//')

CHECKLIST="$PARENT_DIR/$HUB_REPO/_issues/${REPO_NAME}-${ISSUE_NUM}.md"

if [[ ! -f "$CHECKLIST" ]]; then
    echo "ERROR: No checklist found for issue #${ISSUE_NUM}"
    echo "Expected: $CHECKLIST"
    echo ""
    echo "Create _issues/${REPO_NAME}-${ISSUE_NUM}.md in the hub repo before committing."
    exit 1
fi

# 5. Parse Step 5 (Verified)
STEP5_LINE=$(grep -i 'Step 5' "$CHECKLIST" | head -1 || true)

if [[ -z "$STEP5_LINE" ]]; then
    echo "ERROR: Step 5 not found in checklist for issue #${ISSUE_NUM}"
    exit 1
fi

if [[ ! "$STEP5_LINE" =~ ^\-\ \[x\] ]]; then
    echo "ERROR: Step 5 (Verified) not completed in checklist for issue #${ISSUE_NUM}"
    echo "Update _issues/${REPO_NAME}-${ISSUE_NUM}.md to mark Step 5 as done before committing."
    exit 1
fi

# If Step 5 is done (not skipped), verify test files are staged
if [[ ! "$STEP5_LINE" =~ SKIPPED ]]; then
    STAGED_FILES=$(git diff --cached --name-only)
    HAS_TESTS=false

    while IFS= read -r file; do
        case "$file" in
            *test*|*spec*|*_test.*|*.test.*|*.spec.*|test_*|spec_*)
                HAS_TESTS=true
                break
                ;;
        esac
    done <<< "$STAGED_FILES"

    if [[ "$HAS_TESTS" != "true" ]]; then
        echo "WARNING: Step 5 is marked as done (not skipped) but no test files are staged."
        echo "Staged files:"
        echo "$STAGED_FILES"
        echo ""
        echo "If tests live in a separate repo, this is OK. Proceeding."
    fi
fi

echo "Pre-commit check passed for issue #${ISSUE_NUM}"
exit 0
